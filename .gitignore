# --- Build Artifacts ---
# Ignore the entire build/ directory
build/
bin/
obj/
*.o
*.out
*.exe
*.log

# --- CMake (The most important for you) ---
# Ignore CMake cache and generated files
CMakeCache.txt
CMakeFiles/
CMakeScripts/
cmake_install.cmake
install_install.cmake
Makefile
compile_commands.json

# --- vcpkg (Package Manager) ---
# Ignore the installed vcpkg dependencies
vcpkg_installed/
vcpkg_packages/

# --- IDE & Editor Clutter ---
# Visual Studio / VS Code
.vscode/
.vs/
*.user
*.suo
*.db

# Linux / MacOS System files
.DS_Store
*.swp
*~

# --- Scripts & Execution ---
# If you keep secret keys or local test scripts, keep them ignored
*.key
*.pem
local_test.sh
debug_output.txt

# --- Your Application Specifics ---
# If you are saving output data or logs from 'trace'
*.json
*.html
*.txt